# SQL Server test database. Loaded with: node --env-file=.env.sqlserver ...
#
# Translated from the .NET string
# (Data Source=.;Initial Catalog=AlteaTest;User ID=altea-test;Encrypt=True;TrustServerCertificate=True)
# into the form the `mssql` (tedious) driver understands:
#   - Data Source=.  ->  Server=localhost,1433
#     tedious only speaks TCP. Enable the instance's TCP/IP protocol on the
#     static port 1433 (see setup steps), then restart MSSQLSERVER.
#     NOTE: port 1434 on this host is the Dedicated Admin Connection (DAC),
#     which only sysadmins may use — do not point the driver at it.
#   - SQL login (User Id / Password); tedious cannot do Windows integrated auth.
ALTEA_TEST_DB=Server=localhost,1433;Database=AlteaTest;User Id=altea-test;Password=altea-test;Encrypt=true;TrustServerCertificate=true
