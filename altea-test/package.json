{
  "name": "@altea/altea-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./entities/*": {
      "types": "./dist/entities/*.d.ts",
      "default": "./dist/entities/*.js"
    },
    "./logic/*": {
      "types": "./dist/logic/*.d.ts",
      "default": "./dist/logic/*.js"
    }
  },
  "scripts": {
    "build:types": "tspc -b",
    "gen:postgres": "tspc -b && node --enable-source-maps --import ./register.mjs --env-file=.env.postgres dist/test/generateEnvironment.js",
    "gen:sqlserver": "tspc -b && node --enable-source-maps --import ./register.mjs --env-file=.env.sqlserver dist/test/generateEnvironment.js",
    "test:postgres": "tspc -b && node --enable-source-maps --import ./register.mjs --env-file=.env.postgres --test \"dist/test/**/*.test.js\"",
    "test:sqlserver": "tspc -b && node --enable-source-maps --import ./register.mjs --env-file=.env.sqlserver --test \"dist/test/**/*.test.js\""
  },
  "keywords": [],
  "author": "Olmo del Corral",
  "license": "MIT",
  "dependencies": {
    "@altea/altea": "workspace:*",
    "mssql": "^12.6.0",
    "pg": "^8.22.0",
    "quote-transformer": "workspace:*"
  }
}