{
  "name": "@altea/altea-test",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./entities/*": {
      "types": "./dist/entities/*.d.ts",
      "default": "./dist/entities/*.js"
    },
    "./logic/*": {
      "types": "./dist/logic/*.d.ts",
      "default": "./dist/logic/*.js"
    }
  },
  "scripts": {
    "build:types": "tspc -b",
    "build:server": "vite build --config vite.server.config.ts",
    "build": "tspc -b && vite build --config vite.server.config.ts",
    "start:postgres": "node --enable-source-maps --env-file=.env.postgres dist/server-bundle/main.js",
    "start:sqlserver": "node --enable-source-maps --env-file=.env.sqlserver dist/server-bundle/main.js",
    "test": "tspc -b && node --enable-source-maps --import ./register.mjs --test \"dist/test/**/*.test.js\"",
    "test:postgres": "tspc -b && node --enable-source-maps --import ./register.mjs --env-file=.env.postgres --test \"dist/test/**/*.test.js\"",
    "test:sqlserver": "tspc -b && node --enable-source-maps --import ./register.mjs --env-file=.env.sqlserver --test \"dist/test/**/*.test.js\""
  },
  "keywords": [],
  "author": "Olmo del Corral",
  "license": "MIT",
  "dependencies": {
    "@altea/altea": "workspace:*",
    "mssql": "^12.6.0",
    "pg": "^8.22.0",
    "quote-transformer": "workspace:*"
  },
  "devDependencies": {
    "vite": "^7.0.0"
  }
}
