# Copy to .env.postgres or .env.sqlserver and fill in real values.
# ALTEA_TEST_DB selects the dialect: a value starting with "postgres" uses the
# PostgreSQL connector, anything else uses the SQL Server connector.

# PostgreSQL (libpq URL form expected by node-pg):
# ALTEA_TEST_DB=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# SQL Server (mssql connection-string form; use a SQL login, not Windows auth):
# ALTEA_TEST_DB=Server=HOST,PORT;Database=DBNAME;User Id=USER;Password=PASSWORD;TrustServerCertificate=true;Encrypt=true
