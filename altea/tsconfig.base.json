{
  "compilerOptions": {
    "target": "ES2022",
    // ES2022 default libs (DOM/DOM.Iterable — entities/logic use `types: []`, so they get
    // `console`/`URL`/… from DOM) plus ESNext.Disposable for `Disposable` / `Symbol.dispose`
    // (the `using` declaration — e.g. `Clock.overrideNow`). react overrides `lib` itself.
    "lib": ["ES2022", "DOM", "DOM.Iterable", "ESNext.Disposable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "composite": true,
    "incremental": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": [],
    "plugins": [{ "transform": "quote-transformer" }]
  }
}
